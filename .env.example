# Public ingress (prod-like): only gateway is published to the host
GATEWAY_HTTP_PORT=80

# Optional debug ports for docker-compose.dev.yml only
ELASTIC_HTTP_PORT=9200
JAEGER_HTTP_PORT=16686

# Shared JWT settings (must match Auth / Async API / UGC)
JWT_SECRET=replace-with-strong-random-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256

# Auth database
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=replace-with-strong-db-password
AUTH_DB_NAME=auth_db
