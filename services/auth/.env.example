# App
PROJECT_NAME=auth-service
APP_ENV=development
DB_RESET_ON_STARTUP=false

# DB
DB_HOST=auth_postgres
DB_PORT=5432
DB_USER=auth_user
DB_PASSWORD=<change-me>
DB_NAME=auth_db

# Redis
REDIS_URL=redis://auth_redis:6379/0

# JWT
JWT_SECRET=<replace-with-strong-random-jwt-secret-at-least-32-chars>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=2592000

# Docs / OpenAPI
DOCS_URL=/docs
OPENAPI_URL=/openapi.json
CORS_ALLOW_ORIGINS=*
PROXY_TRUSTED_HOSTS=*

# Logging
LOG_LEVEL=INFO

# Observability / Tracing (Jaeger via OTLP HTTP)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=auth-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
REQUEST_ID_HEADER=x-request-id

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=true

# Internal integration
INTERNAL_API_KEY=<change-me-internal-key>

# OAuth (Yandex)
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=http://localhost/api/v1/oauth/yandex/callback

# Bootstrap admin (used by regression as a privileged account)
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_LOGIN=<set-bootstrap-admin-login>
BOOTSTRAP_ADMIN_PASSWORD=<change-me>
