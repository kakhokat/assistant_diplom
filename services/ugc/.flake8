[flake8]
max-line-length = 88
show-source = True
statistics = True

exclude =
    .git,
    __pycache__,
    .mypy_cache,
    .pytest_cache,
    .ruff_cache,
    .venv,
    venv,
    env,
    build,
    dist,
    collect.py,
    research

extend-ignore =
    E203
    W503
    WPS305
    WPS323
    WPS332
    WPS420
    WPS432
    WPS602
    WPS615
    WPS102
    WPS110
    WPS111
    WPS201
    WPS210
    WPS212
    WPS213
    WPS217
    WPS220
    WPS221
    WPS229
    WPS231
    WPS232
    WPS300
    WPS336
    WPS407
    WPS459
    WPS476
    WPS505

per-file-ignores =
    __init__.py:F401

# -----------------------------------------------------------------------------
# Lint policy (wemake-python-styleguide + flake8)
#
# В проекте включён wemake-python-styleguide, но часть правил сознательно
# игнорируется. Причины: учебный проект/прототип, приоритет читаемости и
# простоты сопровождения над «идеальной» стилистикой, а также наличие
# инфраструктурных файлов (gunicorn.conf.py, entrypoints), где WPS-ограничения
# часто дают шум без практической пользы.
#
# Ниже — обоснование каждого кода в extend-ignore.
#
# E203 — несовместимость с Black: Black форматирует с пробелами вокруг ":" в
#        срезах, что конфликтует с E203. Стандартная рекомендация — игнорировать.
# W503 — несовместимость с Black: Black предпочитает перенос до оператора, W503
#        ругается. Стандартная рекомендация — игнорировать.
#
# WPS102 — "incorrect module name pattern":
#          Конфиги типа gunicorn.conf.py и подобные инфраструктурные файлы
#          традиционно называются именно так. Переименование ухудшит
#          узнаваемость/совместимость, поэтому правило отключено.
#
# WPS110 — "wrong variable name":
#          В интеграционном коде используются общепринятые имена домена/протокола:
#          value (Kafka message value), data (payload для ClickHouse), content
#          (HTTP-response content). Эти имена повышают соответствие терминам
#          библиотек и документации и не снижают читаемость в данном контексте.
#
# WPS111 — "too short name":
#          Короткие имена допустимы для стандартных и общеизвестных сущностей:
#          e (exception), v (validator value), s (string). Это распространённый
#          Python-стиль и не ухудшает читаемость в небольших локальных блоках.
#
# WPS201 — "too many imports":
#          В entrypoint-модулях (FastAPI app main) импортов больше из-за сборки
#          зависимостей приложения (роуты, схемы, middleware, метрики и т.д.).
#          Дробление на много файлов ради снижения счётчика импортов ухудшает
#          навигацию. Поэтому правило игнорируется.
#
# WPS210 — "too many local variables":
#          В ETL/worker-функциях есть несколько управляющих переменных состояния
#          (batch, commit_map, timers, client/consumer). Их выделение в отдельные
#          классы/объекты ради снижения счётчика локальных переменных увеличит
#          объём кода и усложнит поток выполнения.
#
# WPS212 — "too many return statements":
#          В util-функциях парсинга timestamp'ов (ETL) много ранних выходов,
#          что делает обработку разных форматов (datetime/epoch/iso/str) проще и
#          читаемее. Альтернатива — длинные if-else с промежуточными флагами.
#
# WPS213 — "too many expressions":
#          В функциях orchestration (worker) встречаются компактные условия и
#          составные проверки (time_ready/size_ready). Это соответствует
#          "business flow" и проще для восприятия, чем избыточная декомпозиция.
#
# WPS217 — "too many await expressions":
#          Worker по природе асинхронный: чтение Kafka, sleep(backoff), commit,
#          запуск HTTP-сервера. Снижение числа await потребует искусственного
#          выноса логики и ухудшит прозрачность I/O границ.
#
# WPS220 — "too deep nesting":
#          Внутри consumer loop есть вложенность из-за обработки батча,
#          парсинга JSON и управления offset’ами. Это отражает реальный поток
#          данных. Уменьшение вложенности возможно, но приведёт к большему числу
#          мелких функций и усложнит передачу контекста (msg/tp/state).
#
# WPS221 — "high Jones Complexity":
#          Отдельные строки могут иметь повышенную "сложность" из-за вызовов
#          сериализации/конфигурации в одну строку. Фактическая логика при этом
#          проста; разбиение ухудшает компактность и не даёт выигрыша в ясности.
#
# WPS229 — "too long try body":
#          Для I/O операций (Kafka send / ClickHouse insert / connect) try включает
#          2–4 строки, потому что важно логировать и перекидывать исключение
#          рядом с вызовом. Искусственное дробление на функции ради 1 строки в try
#          ухудшает читаемость.
#
# WPS231 — "too much cognitive complexity":
#          ETL и parsing функций неизбежно содержат ветвления для поддержки разных
#          форматов входа и сценариев ретраев. Декомпозиция возможна, но делает
#          логику труднее прослеживаемой из-за прыжков между функциями.
#
# WPS232 — "module cognitive complexity too high":
#          Модуль ETL main содержит "worker loop" + HTTP health/metrics, что
#          типично для небольших сервисов. Разделение возможно, но в учебном
#          проекте важнее держать полный runtime-поток в одном месте.
#
# WPS300 — "local folder import":
#          В сервисах используется пакетная структура `app/` и относительные
#          импорты (`from .schemas import ...`). Это нормальная практика для
#          приложений внутри сервиса. Запрет LOCALFOLDER даёт шум без пользы.
#
# WPS336 — "explicit string concatenation":
#          В timestamp parsing замена `Z` на `+00:00` естественно выражается
#          через конкатенацию. Альтернативы (format/replace) не принципиально
#          улучшают читаемость.
#
# WPS407 — "mutable module constant":
#          В проекте константы-колонки должны быть неизменяемыми. Если где-то
#          встречается list/словарь как "константа", это не критично для runtime,
#          но чтобы избежать ложных срабатываний/шума допускаем игнор. При этом
#          предпочтение всё равно отдаётся tuple.
#
# WPS459 — "comparison with float":
#          В парсинге epoch-time используется порог 1e12 для различения секунд и
#          миллисекунд. Это прикладная эвристика, широко используемая на практике.
#
# WPS476 — "await in for loop":
#          Ретрай-циклы закономерно делают await в цикле (sleep/backoff, to_thread).
#          Переписывание на gather здесь не требуется и может усложнить контроль
#          последовательности ретраев.
#
# WPS505 — "nested try":
#          В ETL допускаются вложенные try для разделения ошибок: отдельно ловим
#          JSON decode, отдельно — I/O с ClickHouse/Kafka. Это улучшает диагностику.
# -----------------------------------------------------------------------------
